# ============================================================================
# Ilm AI — environment variables
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ============================================================================

# ---- Database (shared) ----
POSTGRES_USER=ilm
POSTGRES_PASSWORD=ilm
POSTGRES_DB=ilm
DATABASE_URL=postgresql+psycopg2://ilm:ilm@db:5432/ilm

# ---- Backend: app ----
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000

# ---- Backend: auth ----
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=60
REFRESH_TOKEN_TTL_DAYS=30
# Shared server-to-server secret for the Google OAuth bridge.
# Used by the backend (/auth/oauth) AND the frontend NextAuth server route.
AUTH_BRIDGE_SECRET=change-me-to-a-long-random-string

# ---- Backend: LLM ----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# Embeddings run locally via sentence-transformers — no API key needed.
# OPENAI_API_KEY is no longer required.
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384
# Dev-only: skip the local model and use deterministic hash vectors (no RAG quality).
DEV_FAKE_EMBEDDINGS=false

# ---- Backend: file storage (S3 / Supabase) ----
S3_BUCKET=
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
SUPABASE_URL=

# ---- Backend: payments ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=

# ---- Backend + Frontend: monitoring ----
SENTRY_DSN=

# ---- Frontend ----
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-long-random-string
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Bot ----
TELEGRAM_BOT_TOKEN=
BACKEND_INTERNAL_URL=http://backend:8000
